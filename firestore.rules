rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "williansfxtrader@gmail.com");
    }

    // Validation functions
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidServiceOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 &&
             data.device is string && data.device.size() > 0 &&
             data.status in ['pending', 'in-progress', 'completed', 'delivered', 'cancelled'];
    }

    function isValidSale(data) {
      return data.total is number && data.total >= 0 &&
             data.paymentMethod in ['cash', 'credit_card', 'debit_card', 'pix'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidProduct(request.resource.data);
    }

    match /serviceOrders/{orderId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isValidServiceOrder(request.resource.data);
    }

    match /sales/{saleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSale(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
